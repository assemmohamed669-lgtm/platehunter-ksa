# Copy this file to .env.local and fill in your Supabase project values.
# Found in: Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Used in Phase 3 (Whisper transcription). Keep this server-side only —
# never expose it with the NEXT_PUBLIC_ prefix.
OPENAI_API_KEY=sk-...

# Phase 3 — Whisper AI (server-side only, NO NEXT_PUBLIC_ prefix)
OPENAI_API_KEY=sk-...

# Phase 4 — Admin panel (server-side ONLY, never expose with NEXT_PUBLIC_ prefix).
# Found in: Supabase Dashboard -> Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google Gemini AI — قراءة لوحات الكاميرا (مجاني 1500 صورة/يوم)
# احصل على مفتاح مجاني من: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...
